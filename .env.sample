KDECK_HOST=0.0.0.0
KDECK_PORT=18301
KDECK_TOKEN=change-this-token
KDECK_ALLOWED_ROOTS=/home/kojima/work/url2ai,/home/kojima/work/vwork,/home/kojima/work/kmail,/home/kojima/work/rqdb4ai,/home/kojima/work/aixec,/home/kojima/work/horizon,/home/kojima/work/buzblogger,/home/kojima/work/swork,/home/kojima/work/kdeck
KDECK_CODEX_CMD=codex
KDECK_CODEX_MODEL=gpt-5.5
KDECK_CODEX_SANDBOX=workspace-write
KDECK_DEFAULT_EXECUTION_MODE=confirm
KDECK_DATA_DIR=storage

# Goal Queue controller. Keep the real token only in .env on the server.
KDECK_CONTROLLER_ENABLED=1
KDECK_CONTROLLER_TICK_SECONDS=30
KDECK_CONTROLLER_COOLDOWN_SECONDS=900
KDECK_RQDB4AI_API_URL=http://127.0.0.1:18300
KDECK_RQDB4AI_API_TOKEN=change-me-rqdb4ai-token
KDECK_WORKER_STATUS_URL=https://aixec.exbridge.jp/api.php?path=worker/status

# Optional SwarmClaw control plane.
# kdeck talks to SwarmClaw on this server; remote servers run OpenClaw.
SWARMCLAW_BASE_URL=http://127.0.0.1:3456
SWARMCLAW_HOME=/home/kojima/.swarmclaw
KDECK_REMOTE_SSH_KEY=/home/kojima/.ssh/id_swarmclaw_openclaw
KDECK_REMOTE_SSH_USER=kojima
KDECK_REMOTE_SSH_PORT=2222
KDECK_REMOTE_CLAUDE_MODEL=sonnet
KDECK_REMOTE_OLLAMA_MODEL=gemma4:e4b

# Optional: override remote Agent project folder candidates.
# Each Agent can have a different repository layout; list actual project folders, not just parent roots.
# KDECK_AGENTS_JSON=[{"id":"aixec-api-192-168-0-14","label":"AIxEC API server","host":"192.168.0.14","kind":"swarmclaw","gateway_id":"openclaw-192-168-0-14","folder_base":"/home/kojima/bittensorman/aidexx","project_folders":["/home/kojima/bittensorman/aidexx/aixec","/home/kojima/bittensorman/aidexx/url2ai"],"llm_backends":["codex-cli","claude-cli","ollama"],"default_llm_backend":"codex-cli","default_model":"gpt-5.5"}]
