[Unit]
Description=Kurage Agent Deck Python Goal Runner
After=network-online.target kdeck-api.service

[Service]
Type=simple
WorkingDirectory=/home/kojima/work/kdeck
Environment=HOME=/home/kojima
Environment=PATH=/home/kojima/.nvm/versions/node/v24.16.0/bin:/home/kojima/.npm-global/bin:/home/kojima/.local/bin:/usr/local/bin:/usr/bin:/bin
ExecStart=/home/kojima/work/kdeck/scripts/run_python_goal_runner.sh
Restart=on-failure
RestartSec=10

[Install]
WantedBy=default.target
